# .gitignore 최종 상태 (주요 항목 간략)
target/
*.class
.classpath
.project
.settings/

# 민감 정보 파일 제외
src/main/resources/application.properties
src/main/resources/application-*.properties

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*


